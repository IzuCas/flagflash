# FlagFlash API Configuration
# Copy this file to .env and adjust values for your environment

# =============================================================================
# Application Settings
# =============================================================================
APP_ENV=development

# =============================================================================
# Server Configuration
# =============================================================================
SERVER_PORT=9001
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_IDLE_TIMEOUT=60s

# =============================================================================
# PostgreSQL Database Configuration
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=flagflash
DB_PASSWORD=flagflash_secret
DB_NAME=flagflash
DB_SSL_MODE=disable

# Connection Pool Settings
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0

# =============================================================================
# JWT Authentication
# =============================================================================
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRATION=24h

# =============================================================================
# SMTP Email Configuration (for invite emails)
# =============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# =============================================================================
# Application URL (used in invite email links)
# =============================================================================
APP_URL=http://localhost:3000
